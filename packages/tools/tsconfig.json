{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "es6",
        "lib": ["es2018", "dom"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationDir": "./dist/types",
        "outDir": "dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true
    },
    "include": ["src", "../../worker.d.ts"],
    "exclude": ["node_modules", "dist"]
}